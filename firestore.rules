rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPER FUNCTIONS =====
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin (you can expand this)
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate required fields for Arac (Vehicle)
    function isValidArac() {
      return request.resource.data.keys().hasAll([
        'plaka', 'marka', 'model', 'kategori', 'vignetteVar', 
        'kayitTarihi', 'hasarKayitlari', 'qrCode', 'spareKeyCount'
      ]) &&
      request.resource.data.plaka is string &&
      request.resource.data.marka is string &&
      request.resource.data.model is string &&
      request.resource.data.kategori is string &&
      request.resource.data.vignetteVar is bool &&
      request.resource.data.kayitTarihi is timestamp &&
      request.resource.data.hasarKayitlari is list &&
      request.resource.data.qrCode is string &&
      request.resource.data.spareKeyCount is int;
    }
    
    // ===== USERS COLLECTION =====
    
    match /users/{userId} {
      // Users can read and update their own profile
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
      
      // All authenticated users can read user profiles (for presence, notifications, etc.)
      allow read: if isAuthenticated();
      
      // Admins can read all user profiles
      allow read: if isAdmin();
    }
    
    // ===== ARACLAR (VEHICLES) COLLECTION =====
    
    match /araclar/{aracId} {
      // Any authenticated user can read all vehicles
      allow read: if isAuthenticated();
      
      // Create: Must be authenticated and provide valid data
      allow create: if isAuthenticated() && isValidArac();
      
      // Update: Must be authenticated and maintain data integrity
      allow update: if isAuthenticated() && 
        isValidArac() &&
        // Don't allow changing the ID
        request.resource.data.diff(resource.data).unchangedKeys().hasAll(['id']);
      
      // Delete: Any authenticated user can delete (or restrict to admin only)
      allow delete: if isAuthenticated();
      // For admin-only deletion:
      // allow delete: if isAdmin();
    }
    
    // ===== ACTIVITIES COLLECTION =====
    
    match /activities/{activityId} {
      // Any authenticated user can read activities
      allow read: if isAuthenticated();
      
      // Only backend (Cloud Functions) should write activities
      // In practice, you might want to allow app writes too
      allow create: if isAuthenticated();
      
      // No updates or deletes from clients
      allow update, delete: if false;
      // For admin deletion:
      // allow delete: if isAdmin();
    }
    
    // ===== SERVIS KAYITLARI (SERVICE RECORDS) =====
    
    match /servisler/{servisId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        request.resource.data.keys().hasAll([
          'aracId', 'servisTuru', 'aciklama', 'tarih', 'ucret'
        ]);
      allow delete: if isAuthenticated();
    }
    
    // ===== SERVIS FIRMALARI (SERVICE COMPANIES) =====
    
    match /servisFirmalari/{firmaId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        request.resource.data.keys().hasAll([
          'ad', 'iletisim', 'adres', 'uzmanlikAlani'
        ]);
      allow delete: if isAuthenticated();
      // Or restrict to admin only:
      // allow create, update, delete: if isAdmin();
    }
    
    // ===== IADE ISLEMLERI (RETURN OPERATIONS) =====
    
    match /iadeIslemleri/{iadeId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        request.resource.data.keys().hasAll([
          'aracId', 'aracPlaka', 'iadeTarihi', 'fotograflar', 'notlar'
        ]);
      allow delete: if isAuthenticated();
    }
    
    // ===== OFFICE OPERATIONS =====
    
    match /office_operations/{operationId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Alternative collection name (if used)
    match /officeOperations/{operationId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ===== OFFICE RETURNS (CUSTOMER RETURNS) =====
    
    match /office_Return/{returnId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        request.resource.data.keys().hasAll([
          'amount', 'reason', 'date', 'photos', 'notes'
        ]);
      allow delete: if isAuthenticated();
      // Or restrict to admin/manager only:
      // allow create, update, delete: if isAdmin();
    }
    
    // ===== NOTIFICATIONS COLLECTION (for push notifications) =====
    
    match /notifications/{notificationId} {
      // Allow authenticated users to create notifications (for Cloud Function processing)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Only Cloud Functions can update/delete
      allow update, delete: if false;
    }
    
    // ===== FCM TOKENS COLLECTION =====
    
    match /fcmTokens/{userId} {
      // Users can only manage their own tokens
      allow read, write: if isOwner(userId);
    }
    
    // ===== SHUTTLE REPORTS (Generated PDF reports metadata) =====
    
    match /shuttleReports/{reportId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        request.resource.data.keys().hasAll([
          'type', 'startDate', 'endDate', 'totalSessions', 'totalCustomers', 'totalTrips', 'generatedAt'
        ]);
      allow delete: if isAuthenticated();
    }
    
    // ===== REPORT HISTORY (if you add this feature) =====
    
    match /raporGecmisi/{raporId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    
    // ===== PROTOCOLS COLLECTION =====
    
    match /protocols/{protocolId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ===== USER PRESENCE COLLECTION =====
    
    match /userPresence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId);
    }
    
    // ===== SHUTTLE LOCATIONS =====
    
    match /shuttleLocations/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId);
    }
    
    // ===== SHUTTLE ENTRIES =====
    
    match /shuttleEntries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    
    // ===== SHUTTLE SESSIONS =====
    
    match /shuttleSessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    
    // ===== WORK SCHEDULES (Timetable) =====
    
    match /workSchedules/{scheduleId} {
      // Allow all operations for authenticated users
      allow read, write: if isAuthenticated();
    }
    
    // ===== TEST COLLECTION (for testing purposes) =====
    
    match /test/{testId} {
      allow read, write: if isAuthenticated();
    }
    
    // ===== ADMIN TESTS COLLECTION =====
    
    match /adminTests/{testId} {
      allow read, write: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ===== VACATION TIMES COLLECTION =====
    
    match /vacationTimes/{vacationId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ===== ADMIN TEST LOGS COLLECTION =====
    
    match /adminTestLogs/{logId} {
      // Only authenticated users can read (for admin review)
      allow read: if isAuthenticated();
      // Only authenticated users can write (for logging test results)
      allow create: if isAuthenticated();
      // No updates or deletes from clients (logs are immutable)
      allow update, delete: if false;
    }
  }
}

