rules_version = '2';

// ============================================================================
// IMPORTANT: PERMANENT PERMISSION RULES - DO NOT MODIFY
// ============================================================================
// These rules are configured to allow ALL authenticated users to perform
// ALL operations (read, write, create, update, delete, list) on ALL collections.
// This configuration is PERMANENT and should NOT be changed.
// All authenticated users have full access to:
// - Iade (Return) operations
// - Check Out (Exit) operations  
// - Damage records
// - Office operations
// - Work schedules
// - Admin tests and logs
// - All other collections
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPER FUNCTIONS =====
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin (you can expand this)
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is demo user
    // Supports: demo@gmail.com (old), *_demo@* pattern, demo_*@* pattern, @demo.example.com
    function isDemoUser() {
      return isAuthenticated() && 
        (request.auth.token.email == 'demo@gmail.com' ||
         request.auth.token.email.matches('.*_demo@.*') ||
         request.auth.token.email.matches('demo_.*@.*') ||
         request.auth.token.email.matches('.*@demo\\.example\\.com'));
    }
    
    // Check if user is production user (not demo)
    function isProductionUser() {
      return isAuthenticated() && !isDemoUser();
    }
    
    // Validate required fields for Arac (Vehicle)
    function isValidArac() {
      return request.resource.data.keys().hasAll([
        'plaka', 'marka', 'model', 'kategori', 'vignetteVar', 
        'kayitTarihi', 'hasarKayitlari', 'qrCode', 'spareKeyCount'
      ]) &&
      request.resource.data.plaka is string &&
      request.resource.data.marka is string &&
      request.resource.data.model is string &&
      request.resource.data.kategori is string &&
      request.resource.data.vignetteVar is bool &&
      request.resource.data.kayitTarihi is timestamp &&
      request.resource.data.hasarKayitlari is list &&
      request.resource.data.qrCode is string &&
      request.resource.data.spareKeyCount is int;
    }
    
    // ===== HELPER FUNCTION: CHECK SUPER ADMIN =====
    
    // Check if user is super admin (admin@gmail.com)
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == 'admin@gmail.com';
    }
    
    // Check if user belongs to a franchise
    function belongsToFranchise(franchiseId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.franchiseId == franchiseId;
    }
    
    // Check if user is active
    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }
    
    // Check if demo is not expired
    function isDemoNotExpired() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !userData.isDemo || 
        (userData.demoExpiresAt != null && userData.demoExpiresAt > request.time);
    }
    
    // ===== FRANCHISES COLLECTION (NEW) =====
    // Only super admin can manage franchises
    
    match /franchises/{franchiseId} {
      // Super admin can do everything
      allow read, write, delete: if isSuperAdmin();
      
      // Authenticated users can read their own franchise
      allow read: if isAuthenticated() && belongsToFranchise(franchiseId);
    }
    
    // Allow collection-level queries for franchises
    match /franchises {
      allow list: if isSuperAdmin();
    }
    
    // ===== PLATE FORMATS COLLECTION (NEW) =====
    // Read-only for authenticated users, write by super admin
    
    match /plateFormats/{countryId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    // Allow collection-level queries for plateFormats
    match /plateFormats {
      allow list: if isAuthenticated();
    }
    
    // ===== USERS COLLECTION =====
    
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      
      // Users can update their own profile (limited fields)
      allow update: if isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'isAdmin', 'franchiseId', 'isDemo', 'demoExpiresAt', 'isActive', 'maxUsers']);
      
      // Super admin can do everything with users
      allow read, write, delete: if isSuperAdmin();
      
      // Franchise admins can read users in their franchise
      allow read: if isAuthenticated() && 
        resource.data.franchiseId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.franchiseId;
    }
    
    // Allow collection-level queries for users
    match /users {
      allow list: if isSuperAdmin();
    }
    
    // ===== ARACLAR (VEHICLES) COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage vehicles
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /araclar/{aracId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for araclar
    match /araclar {
      allow list: if isProductionUser();
    }
    
    // ===== ACTIVITIES COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage activities
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /activities/{activityId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for activities
    match /activities {
      allow list: if isProductionUser();
    }
    
    // ===== SERVIS KAYITLARI (SERVICE RECORDS) =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage service records
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /servisler/{servisId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for servisler
    match /servisler {
      allow list: if isProductionUser();
    }
    
    // ===== SERVIS FIRMALARI (SERVICE COMPANIES) =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage service companies
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /servisFirmalari/{firmaId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for servisFirmalari
    match /servisFirmalari {
      allow list: if isProductionUser();
    }
    
    // ===== IADE ISLEMLERI (RETURN OPERATIONS) =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage return operations
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /iadeIslemleri/{iadeId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for iadeIslemleri
    match /iadeIslemleri {
      allow list: if isProductionUser();
    }
    
    // ===== EXIT ISLEMLERI (CHECK OUT OPERATIONS) =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage check out operations
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /exitIslemleri/{exitId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for exitIslemleri
    match /exitIslemleri {
      allow list: if isProductionUser();
    }
    
    // ===== OFFICE OPERATIONS =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage office operations
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /office_operations/{operationId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for office_operations
    match /office_operations {
      allow list: if isProductionUser();
    }
    
    // Alternative collection name (if used)
    match /officeOperations/{operationId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries for officeOperations
    match /officeOperations {
      allow list: if isProductionUser();
    }
    
    // ===== OFFICE RETURNS (CUSTOMER RETURNS) =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage office returns
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /office_Return/{returnId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for office_Return
    match /office_Return {
      allow list: if isProductionUser();
    }
    
    // ===== NOTIFICATIONS COLLECTION (for push notifications) =====
    
    match /notifications/{notificationId} {
      // Allow authenticated users to create notifications (for Cloud Function processing)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Only Cloud Functions can update/delete
      allow update, delete: if false;
    }
    
    // ===== FCM TOKENS COLLECTION =====
    
    match /fcmTokens/{userId} {
      // Users can only manage their own tokens
      allow read, write: if isOwner(userId);
    }
    
    // ===== SHUTTLE REPORTS (Generated PDF reports metadata) =====
    
    match /shuttleReports/{reportId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        request.resource.data.keys().hasAll([
          'type', 'startDate', 'endDate', 'totalSessions', 'totalCustomers', 'totalTrips', 'generatedAt'
        ]);
      allow delete: if isAuthenticated();
    }
    
    // ===== REPORT HISTORY (if you add this feature) =====
    
    match /raporGecmisi/{raporId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    
    // ===== PROTOCOL TEMPLATES (Web App Specific) =====
    // Allow read/list/write for everyone (no authentication required)
    match /protocolTemplates/{templateCode} {
      allow read, list: if true;
      allow create, update, delete: if true;
    }
    
    // Allow collection-level queries (list operations) for protocolTemplates
    match /protocolTemplates {
      allow list: if true;
    }
    
    // ===== PROTOCOLS COLLECTION =====
    
    match /protocols/{protocolId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Allow collection-level queries (list operations) for protocols
    match /protocols {
      allow list: if isAuthenticated();
    }
    
    // ===== USER PRESENCE COLLECTION =====
    
    match /userPresence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId);
    }
    
    // ===== SHUTTLE ENTRIES =====
    
    match /shuttleEntries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    
    // ===== SHUTTLE SESSIONS =====
    
    match /shuttleSessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    
    // ===== TRANSACTIONS COLLECTION (ERP - Web App Specific) =====
    
    match /transactions/{transactionId} {
      allow read, list: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Allow collection-level queries (list operations) for transactions
    match /transactions {
      allow list: if isAuthenticated();
    }
    
    // ===== CUSTOMERS COLLECTION (ERP - Web App Specific) =====
    
    match /customers/{customerId} {
      allow read, list: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Allow collection-level queries (list operations) for customers
    match /customers {
      allow list: if isAuthenticated();
    }
    
    // ===== ACCIDENTS COLLECTION (ERP - Web App Specific) =====
    
    match /accidents/{accidentId} {
      allow read, list: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Allow collection-level queries (list operations) for accidents
    match /accidents {
      allow list: if isAuthenticated();
    }
    
    // ===== ACCIDENT CODES COLLECTION (ERP - Web App Specific) =====
    
    match /accidentCodes/{code} {
      allow read, list: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Allow collection-level queries (list operations) for accidentCodes
    match /accidentCodes {
      allow list: if isAuthenticated();
    }
    
    // ===== TRAFFIC FINES COLLECTION (Web App Specific) =====
    // Allow read/list/write for everyone (no authentication required)
    match /trafficFines/{fineId} {
      allow read, list: if true;
      allow create, update, delete: if true;
    }
    
    // Allow collection-level queries (list operations) for trafficFines
    match /trafficFines {
      allow list: if true;
    }
    
    // ===== BANKING TRANSACTIONS COLLECTION (Web App Specific) =====
    // Allow read/list/write for everyone (no authentication required)
    match /bankingTransactions/{transactionId} {
      allow read, list: if true;
      allow create, update, delete: if true;
    }
    
    // Allow collection-level queries (list operations) for bankingTransactions
    match /bankingTransactions {
      allow list: if true;
    }
    
    // ===== ADDITIONAL SALES COLLECTION (Web App Specific) =====
    // Allow read/list/write for everyone (no authentication required)
    match /additionalSales/{saleId} {
      allow read, list: if true;
      allow create, update, delete: if true;
    }
    
    // Allow collection-level queries (list operations) for additionalSales
    match /additionalSales {
      allow list: if true;
    }
    
    // ===== WORK SCHEDULES (Timetable) =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage work schedules
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /workSchedules/{scheduleId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for workSchedules
    match /workSchedules {
      allow list: if isProductionUser();
    }
    
    // Alternative collection name (if used)
    match /work_schedules/{scheduleId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries for work_schedules
    match /work_schedules {
      allow list: if isProductionUser();
    }
    
    // ===== TEST COLLECTION (for testing purposes) =====
    
    match /test/{testId} {
      allow read, write: if isAuthenticated();
    }
    
    // ===== ADMIN TESTS COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage admin tests
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /adminTests/{testId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for adminTests
    match /adminTests {
      allow list: if isProductionUser();
    }
    
    // ===== VACATION TIMES COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage vacation times
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /vacationTimes/{vacationId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for vacationTimes
    match /vacationTimes {
      allow list: if isProductionUser();
    }
    
    // ===== ASSISTANT COMPANIES COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage assistant companies
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /assistantCompanies/{companyId} {
      // Production users only (demo users blocked)
      allow read, write: if isProductionUser();
      allow delete: if isProductionUser();
    }
    
    // Allow collection-level queries (list operations) for assistantCompanies
    match /assistantCompanies {
      allow list: if isProductionUser();
    }
    
    // ===== ADMIN TEST LOGS COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage admin test logs
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /adminTestLogs/{logId} {
      // Production users only (demo users blocked)
      allow read: if isProductionUser();
      // Allow write for setData operations (setData can create or update)
      // Using 'write' covers both create and update operations
      allow write: if isProductionUser();
      // No deletes from clients (logs should be preserved)
      allow delete: if false;
    }
    
    // Allow collection-level queries (list operations)
    match /adminTestLogs {
      allow list: if isProductionUser();
    }
    
    // ============================================================================
    // DEMO COLLECTIONS - ONLY ACCESSIBLE BY DEMO USER (demo@gmail.com)
    // ============================================================================
    // Production users CANNOT access demo collections
    // Demo user CANNOT access production collections
    // ============================================================================
    
    // ===== DEMO ARACLAR (DEMO VEHICLES) =====
    match /demo_araclar/{aracId} {
      // Only demo user can access
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_araclar {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO ACTIVITIES =====
    match /demo_activities/{activityId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_activities {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO SERVIS KAYITLARI (DEMO SERVICE RECORDS) =====
    match /demo_servisler/{servisId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_servisler {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO SERVIS FIRMALARI (DEMO SERVICE COMPANIES) =====
    match /demo_servisFirmalari/{firmaId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_servisFirmalari {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO IADE ISLEMLERI (DEMO RETURN OPERATIONS) =====
    match /demo_iadeIslemleri/{iadeId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_iadeIslemleri {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO EXIT ISLEMLERI (DEMO CHECK OUT OPERATIONS) =====
    match /demo_exitIslemleri/{exitId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_exitIslemleri {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO OFFICE OPERATIONS =====
    match /demo_office_operations/{operationId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_office_operations {
      allow list: if isDemoUser();
    }
    match /demo_officeOperations/{operationId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_officeOperations {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO OFFICE RETURNS =====
    match /demo_office_Return/{returnId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_office_Return {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO WORK SCHEDULES =====
    match /demo_workSchedules/{scheduleId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_workSchedules {
      allow list: if isDemoUser();
    }
    match /demo_work_schedules/{scheduleId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_work_schedules {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO VACATION TIMES =====
    match /demo_vacationTimes/{vacationId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_vacationTimes {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO ASSISTANT COMPANIES =====
    match /demo_assistantCompanies/{companyId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_assistantCompanies {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO ADMIN TESTS =====
    match /demo_adminTests/{testId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_adminTests {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO ADMIN TEST LOGS =====
    match /demo_adminTestLogs/{logId} {
      allow read: if isDemoUser();
      allow write: if isDemoUser();
      allow delete: if false;
    }
    match /demo_adminTestLogs {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO SHUTTLE ENTRIES =====
    match /demo_shuttleEntries/{entryId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_shuttleEntries {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO SHUTTLE SESSIONS =====
    match /demo_shuttleSessions/{sessionId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_shuttleSessions {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO SHUTTLE REPORTS =====
    match /demo_shuttleReports/{reportId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_shuttleReports {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO NOTIFICATIONS =====
    match /demo_notifications/{notificationId} {
      allow read: if isDemoUser();
      allow create: if isDemoUser();
      allow update, delete: if false;
    }
    match /demo_notifications {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO FCM TOKENS =====
    match /demo_fcmTokens/{userId} {
      allow read, write: if isDemoUser() && isOwner(userId);
    }
    match /demo_fcmTokens {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO USER PRESENCE =====
    match /demo_userPresence/{userId} {
      allow read: if isDemoUser();
      allow write: if isDemoUser() && isOwner(userId);
    }
    match /demo_userPresence {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO PROTOCOLS =====
    match /demo_protocols/{protocolId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_protocols {
      allow list: if isDemoUser();
    }
    
    // ===== DEMO REPORT HISTORY =====
    match /demo_raporGecmisi/{raporId} {
      allow read, write: if isDemoUser();
      allow delete: if isDemoUser();
    }
    match /demo_raporGecmisi {
      allow list: if isDemoUser();
    }
    
    // ============================================================================
    // YENİ: DEMO ENVIRONMENTS SUBCOLLECTION RULES
    // ============================================================================
    // Production rules değişmeyecek, sadece bu yeni bölüm eklendi
    // Her demo kullanıcı için izole subcollection yapısı: demo_environments/{userId}/*
    // ============================================================================
    
    // Demo environments parent collection
    match /demo_environments/{userId} {
      // Kullanıcı sadece kendi demo environment'ına erişebilir
      allow read, write: if isDemoUser() && request.auth.uid == userId;
      
      // Subcollections için recursive wildcard - tüm subcollections için geçerli
      match /{collectionName}/{documentId=**} {
        allow read, write: if isDemoUser() && request.auth.uid == userId;
        allow delete: if isDemoUser() && request.auth.uid == userId;
      }
      
      // Collection-level list operations
      match /{collectionName} {
        allow list: if isDemoUser() && request.auth.uid == userId;
      }
    }
    
    // Demo environments root-level list (kullanıcılar sadece kendi environment'larını görebilir)
    match /demo_environments {
      allow list: if isDemoUser();
    }
  }
}

