rules_version = '2';

// ============================================================================
// FIRESTORE SECURITY RULES - FRANCHISE DATA ISOLATION + RBAC + TRIAL USERS
// ============================================================================
// Access control layers:
//   1. FRANCHISE ISOLATION: Production users can only access documents
//      matching their franchiseId (e.g. "ch" for Switzerland, "tr" for Turkey)
//   2. RBAC: Only `globaladmin` bypasses franchise filtering (cross-franchise). Superadmin is scoped to users.franchiseId.
// ALL roles (manager, staff, viewer, admin) have FULL access to their franchise.
// Elevated admins (superadmin, globaladmin) have access to admin panel collections (adminTests, adminTestLogs).
//
// SAFETY: exists() checks prevent errors when user document is missing.
//         Trial users are normal franchise users with time-limited login.
//
// DEPLOYMENT ORDER: (1) Run migration, (2) Deploy app code, (3) Deploy rules
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPER FUNCTIONS =====
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get user document (returns null if not found)
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Check if user is admin (you can expand this)
    function isAdmin() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && ud.data.role == 'admin';
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isProductionUser() {
      return isAuthenticated();
    }
    
    // Validate required fields for Arac (Vehicle)
    function isValidArac() {
      return request.resource.data.keys().hasAll([
        'plaka', 'marka', 'model', 'kategori', 'vignetteVar', 
        'kayitTarihi', 'hasarKayitlari', 'qrCode', 'spareKeyCount'
      ]) &&
      request.resource.data.plaka is string &&
      request.resource.data.marka is string &&
      request.resource.data.model is string &&
      request.resource.data.kategori is string &&
      request.resource.data.vignetteVar is bool &&
      request.resource.data.kayitTarihi is timestamp &&
      request.resource.data.hasarKayitlari is list &&
      request.resource.data.qrCode is string &&
      request.resource.data.spareKeyCount is int;
    }
    
    // ===== HELPER: ELEVATED ADMIN (superadmin OR globaladmin) =====
    
    function userRoleLower() {
      let ud = getUserDoc();
      return ud != null && ud.data.keys().hasAny(['role']) && ud.data.role is string
        ? ud.data.role.lower()
        : '';
    }

    function userRoleScopeLevel() {
      let ud = getUserDoc();
      return ud != null &&
        ud.data.keys().hasAny(['roleScope']) &&
        ud.data.roleScope is map &&
        ud.data.roleScope.keys().hasAny(['level']) &&
        ud.data.roleScope.level is string
        ? ud.data.roleScope.level.lower()
        : '';
    }

    function isGlobalAdminRole() {
      return userRoleLower() == 'globaladmin' || userRoleScopeLevel() == 'global';
    }

    function isElevatedAdmin() {
      return isAuthenticated() && getUserDoc() != null &&
        (userRoleLower() == 'superadmin' || isGlobalAdminRole());
    }

    // Legacy root domain collections (/araclar, /exitIslemleri, …).
    // Production apps use franchises/{franchiseId}/{collection} only.
    function legacyRootDomainFrozenRead() {
      return isElevatedAdmin();
    }

    function isGlobalAdminOnly() {
      return isAuthenticated() && getUserDoc() != null && isGlobalAdminRole();
    }

    function isSuperAdminOnly() {
      return isAuthenticated() && getUserDoc() != null && userRoleLower() == 'superadmin';
    }
    
    // Franchise manager: operational lead (work-hour visibility for whole team)
    function isFranchiseManagerRole() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && ud.data.role == 'manager';
    }

    function isAnnouncementPublisher() {
      return userRoleLower() == 'manager' ||
        userRoleLower() == 'admin' ||
        userRoleLower() == 'superadmin' ||
        userRoleLower() == 'globaladmin';
    }

    // ===== UNIFIED roleScope HELPERS (sync with green-motion-web rules) =====
    function userRoleScopeCountry() {
      let ud = getUserDoc();
      return ud != null &&
        ud.data.keys().hasAny(['roleScope']) &&
        ud.data.roleScope is map &&
        ud.data.roleScope.keys().hasAny(['countryCode']) &&
        ud.data.roleScope.countryCode is string
        ? ud.data.roleScope.countryCode.lower()
        : (
          ud != null && ud.data.keys().hasAny(['countryCode']) && ud.data.countryCode is string
            ? ud.data.countryCode.lower()
            : ''
        );
    }

    function userRoleScopeFranchiseIds() {
      let ud = getUserDoc();
      return ud != null &&
        ud.data.keys().hasAny(['roleScope']) &&
        ud.data.roleScope is map &&
        ud.data.roleScope.keys().hasAny(['franchiseIds']) &&
        ud.data.roleScope.franchiseIds is list
        ? ud.data.roleScope.franchiseIds
        : [];
    }

    function userIsGlobalScope() {
      return isGlobalAdminRole();
    }

    function franchiseDocCountryMatchesUser(franchisePathId) {
      let ud = getUserDoc();
      let fr = get(/databases/$(database)/documents/franchises/$(franchisePathId));
      let userCountry = userRoleScopeCountry();
      return ud != null &&
        fr != null &&
        fr.data.keys().hasAny(['countryCode']) &&
        userCountry != '' &&
        fr.data.countryCode.lower() == userCountry;
    }

    function userHasMembershipForFranchise(franchisePathId) {
      let ud = getUserDoc();
      return ud != null &&
        ud.data.keys().hasAny(['franchiseMemberships']) &&
        ud.data.franchiseMemberships[franchisePathId] == true;
    }

    function userHasCountryWideScope() {
      let ud = getUserDoc();
      return ud != null &&
        ud.data.keys().hasAny(['scopeLevel']) &&
        ud.data.scopeLevel == 'country_all';
    }

    function isBranchUnderTwoLetterFranchiseRoot(primary, pathFranchise) {
      return primary is string &&
        pathFranchise is string &&
        primary.size() == 2 &&
        pathFranchise.size() > 3 &&
        pathFranchise.lower().matches('^' + primary.lower() + '_.*');
    }

    function userCountryWideForFranchise(franchisePathId) {
      return (
        (userRoleScopeLevel() == 'country' && userRoleScopeFranchiseIds().size() == 0)
        || userHasCountryWideScope()
      ) && franchiseDocCountryMatchesUser(franchisePathId);
    }

    function userHasExplicitFranchiseAccess(franchisePathId) {
      return userRoleScopeFranchiseIds().hasAny([franchisePathId])
        || userHasMembershipForFranchise(franchisePathId);
    }

    function userMatchesFranchiseId(franchiseFieldValue) {
      let ud = getUserDoc();
      return ud != null && franchiseFieldValue is string && (
        userIsGlobalScope() ||
        userHasExplicitFranchiseAccess(franchiseFieldValue) ||
        userCountryWideForFranchise(franchiseFieldValue) ||
        (
          ud.data.keys().hasAny(['franchiseId']) &&
          ud.data.franchiseId is string &&
          franchiseFieldValue.lower() == ud.data.franchiseId.lower()
        ) ||
        (
          ud.data.keys().hasAny(['franchiseId']) &&
          ud.data.franchiseId is string &&
          isBranchUnderTwoLetterFranchiseRoot(ud.data.franchiseId, franchiseFieldValue) &&
          franchiseDocCountryMatchesUser(franchiseFieldValue)
        )
      );
    }

    function canAccessFranchise(fid) {
      return userIsGlobalScope() || userMatchesFranchiseId(fid);
    }

    // Check if user belongs to a franchise
    function belongsToFranchise(franchiseId) {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null &&
        userMatchesFranchiseId(franchiseId);
    }
    
    // Check if user is active
    function isActiveUser() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        ud.data.isActive == true ||
        ud.data.isActive == 1 ||
        ud.data.isActive == "1" ||
        !ud.data.keys().hasAny(["isActive"])
      );
    }
    
    // ===== FRANCHISE DATA ISOLATION HELPERS =====
    // Single get() per function using let + null check pattern
    // ALL roles (manager, staff, viewer, admin) get FULL franchise access
    // ONLY globaladmin bypasses franchise filtering (cross-franchise)
    // Trial users are NOT isolated by path; all active users use franchise paths.
    
    // Check if user has franchise access to read a document
    // NOTE: Documents WITHOUT a franchiseId field are denied for non-elevated users
    // to prevent legacy/malformed data from bypassing franchise isolation.
    function hasFranchiseReadAccess() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        isGlobalAdminRole() ||
        (
          (ud.data.isActive == true ||
           ud.data.isActive == 1 ||
           ud.data.isActive == "1" ||
           !ud.data.keys().hasAny(["isActive"])) &&
          resource.data.keys().hasAny(["franchiseId"]) &&
          userMatchesFranchiseId(resource.data.franchiseId)
        )
      );
    }

    // Check if user has franchise access to write a document
    // NOTE: Writes must include franchiseId matching the user's franchise.
    function hasFranchiseWriteAccess() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        isGlobalAdminRole() ||
        (
          (ud.data.isActive == true ||
           ud.data.isActive == 1 ||
           ud.data.isActive == "1" ||
           !ud.data.keys().hasAny(["isActive"])) &&
          request.resource.data.keys().hasAny(["franchiseId"]) &&
          userMatchesFranchiseId(request.resource.data.franchiseId)
        )
      );
    }

    // Check if user has franchise access to delete a document
    // NOTE: Documents WITHOUT franchiseId are only deletable by elevated admin.
    function hasFranchiseDeleteAccess() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        isGlobalAdminRole() ||
        (
          (ud.data.isActive == true ||
           ud.data.isActive == 1 ||
           ud.data.isActive == "1" ||
           !ud.data.keys().hasAny(["isActive"])) &&
          resource.data.keys().hasAny(["franchiseId"]) &&
          userMatchesFranchiseId(resource.data.franchiseId)
        )
      );
    }

    // Scoped-path access helper: franchises/{franchiseId}/{collection}/{doc}
    function hasScopedFranchiseAccess(franchiseId) {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        ud.data.isActive == true ||
        ud.data.isActive == 1 ||
        ud.data.isActive == "1" ||
        !ud.data.keys().hasAny(["isActive"])
      ) &&
        (isGlobalAdminRole() ||
         userMatchesFranchiseId(franchiseId));
    }

    function isScopedExitReturnSoftDeleteUpdate(collectionName) {
      return (collectionName == 'exitIslemleri' || collectionName == 'iadeIslemleri') &&
        (request.resource.data.isDeleted == true || request.resource.data.isDeleted == 1);
    }

    function canSoftDeleteScopedExitOrReturn(collectionName, pathFranchiseId) {
      return isScopedExitReturnSoftDeleteUpdate(collectionName) &&
        hasScopedFranchiseAccess(pathFranchiseId) &&
        isActiveUser() &&
        (
          isGlobalAdminRole() ||
          userMatchesFranchiseId(pathFranchiseId)
        );
    }

    function isTurkeyFranchiseId(franchiseId) {
      return franchiseId is string && franchiseId.lower().matches('tr.*');
    }

    function isSwitzerlandFranchiseId(franchiseId) {
      return franchiseId is string && franchiseId.lower().matches('ch.*');
    }

    function isGermanyFranchiseId(franchiseId) {
      return franchiseId is string && franchiseId.lower().matches('de.*');
    }

    function officeOperationsAllowedFranchise(franchiseId) {
      return isTurkeyFranchiseId(franchiseId)
        || isSwitzerlandFranchiseId(franchiseId)
        || isGermanyFranchiseId(franchiseId);
    }

    function userRoleIsGarage() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null &&
        ud.data.keys().hasAny(['role']) &&
        ud.data.role == 'garage';
    }

    function userLinkedGarageId() {
      let ud = getUserDoc();
      return ud != null ? (
        ud.data.keys().hasAny(['linkedGarageId']) && ud.data.linkedGarageId is string
          ? ud.data.linkedGarageId
          : (
            ud.data.keys().hasAny(['garageId']) && ud.data.garageId is string
              ? ud.data.garageId
              : ''
          )
      ) : '';
    }

    function garageJobTargetMatchesUser(jobData) {
      let linked = userLinkedGarageId().lower();
      return linked != '' &&
        jobData.keys().hasAny(['targetGarageId']) &&
        jobData.targetGarageId is string &&
        jobData.targetGarageId.lower() == linked;
    }

    function isGaragePortalCompletionUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['status', 'completedAt', 'completionPhotoURLs', 'completionNotes', 'updatedAt'])
        && request.resource.data.status == 'completed'
        && request.resource.data.completedAt is timestamp
        && garageJobTargetMatchesUser(resource.data);
    }

    /// Office-related collections that are not enabled for every country on scoped franchise paths.
    function scopedRestrictedOfficeCollection(collectionName) {
      return collectionName in ['office_operations', 'office_Return', 'traffic_accident_contracts', 'police_reports'];
    }

    function scopedRestrictedOfficeAccess(collectionName, pathFranchiseId) {
      return (collectionName == 'office_operations'
          && officeOperationsAllowedFranchise(pathFranchiseId))
        || (collectionName == 'office_Return'
          && (isTurkeyFranchiseId(pathFranchiseId) || isSwitzerlandFranchiseId(pathFranchiseId)))
        || ((collectionName == 'traffic_accident_contracts' || collectionName == 'police_reports')
          && isSwitzerlandFranchiseId(pathFranchiseId));
    }

    // Front-desk customer intakes (web kiosk): admin SDK creates; staff/manager/admin can manage records.
    function isFrontDeskStaffCompletionUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['resCode', 'vehiclePlate', 'status', 'completedAt'])
        && request.resource.data.status == 'completed'
        && request.resource.data.resCode is string
        && request.resource.data.vehiclePlate is string
        && request.resource.data.resCode.size() > 0
        && request.resource.data.vehiclePlate.size() > 0
        && request.resource.data.completedAt is timestamp
        && resource.data.status == 'awaiting_staff';
    }

    // Public customer QR forms (return.html / checkout.html) — no auth required.
    function publicCustomerSelfFillPayloadValid(token, franchiseId) {
      return request.resource.data.keys().hasAll([
        'token', 'firstName', 'lastName', 'email', 'franchiseId', 'signatureBase64'
      ])
      && request.resource.data.token == token
      && request.resource.data.franchiseId == franchiseId
      && request.resource.data.firstName is string
      && request.resource.data.lastName is string
      && request.resource.data.email is string
      && request.resource.data.signatureBase64 is string
      && request.resource.data.firstName.size() > 0
      && request.resource.data.lastName.size() > 0
      && request.resource.data.email.size() > 0
      && request.resource.data.signatureBase64.size() > 0
      && request.resource.data.signatureBase64.size() < 900000;
    }

    function publicCustomerSelfFillNotSubmittedYet() {
      return !('submittedAt' in resource.data)
        && !('signatureBase64' in resource.data);
    }

    // Front-desk manage roles (edit/delete/bulk-delete from web).
    function isFrontDeskManagerOrStaffRole() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        ud.data.role == 'staff' ||
        ud.data.role == 'shuttle' ||
        ud.data.role == 'manager' ||
        ud.data.role == 'admin' ||
        ud.data.role == 'superadmin' ||
        ud.data.role == 'globaladmin'
      );
    }
    
    // ===== FRANCHISES COLLECTION (NEW) =====
    // Only super admin can manage franchises
    
    match /franchises/{franchiseId} {
      // Global admin: all franchise documents
      allow read, write, delete: if isGlobalAdminOnly();
      
      // Login screen (before auth): read active franchise root metadata for country/franchise picker
      allow read: if resource.data.keys().hasAll(['countryCode', 'franchiseId'])
        && resource.data.countryCode is string
        && resource.data.franchiseId is string
        && resource.data.isActive != false;
      
      // Authenticated users can read their own franchise
      allow read: if isAuthenticated() && belongsToFranchise(franchiseId);
      
      // Franchise superadmin or admin may manage their own franchise doc only
      allow write, delete: if belongsToFranchise(franchiseId) && (isAdmin() || isSuperAdminOnly());
      
      // Scoped notification queue (Cloud Functions processor)
      match /notifications/{notificationId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create: if hasScopedFranchiseAccess(franchiseId);
        allow update, delete: if false;
      }
      
      // Scoped outgoing email queue (Cloud Functions processor)
      match /outgoingEmails/{emailId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create: if hasScopedFranchiseAccess(franchiseId);
        allow update, delete: if false;
      }
      
      // Per-user work time entries (strict read: own row OR franchise manager OR superadmin)
      match /workTimeEntries/{docId} {
        allow read: if isElevatedAdmin() || (
          hasScopedFranchiseAccess(franchiseId) && (
            isFranchiseManagerRole() ||
            (resource.data.keys().hasAll(['userId']) && resource.data.userId == request.auth.uid)
          )
        );
        allow create: if hasScopedFranchiseAccess(franchiseId) &&
          request.resource.data.keys().hasAll([
            'franchiseId', 'userId', 'dayKey', 'clockIn', 'clockOut', 'totalMinutes', 'updatedAt'
          ]) &&
          request.resource.data.franchiseId == franchiseId &&
          request.resource.data.userId == request.auth.uid;
        allow update: if hasScopedFranchiseAccess(franchiseId) &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == resource.data.userId &&
          resource.data.franchiseId == franchiseId &&
          request.resource.data.franchiseId == franchiseId;
        allow delete: if hasScopedFranchiseAccess(franchiseId) &&
          resource.data.userId == request.auth.uid;
      }
      
      // Monthly plan files uploaded by managers/admins for each franchise
      match /workTimePlans/{docId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create, update: if hasScopedFranchiseAccess(franchiseId) && (
          isFranchiseManagerRole() || isElevatedAdmin() || isAdmin()
        );
        allow delete: if hasScopedFranchiseAccess(franchiseId) && (
          isFranchiseManagerRole() || isElevatedAdmin() || isAdmin()
        );
      }

      match /frontDeskCustomers/{docId} {
        allow read: if hasScopedFranchiseAccess(franchiseId) && isActiveUser();
        allow create: if false;
        allow update: if hasScopedFranchiseAccess(franchiseId) && isActiveUser() && (
          isFrontDeskStaffCompletionUpdate() ||
          isFrontDeskManagerOrStaffRole()
        );
        allow delete: if hasScopedFranchiseAccess(franchiseId) && isActiveUser() && isFrontDeskManagerOrStaffRole();
      }

      // Deleted item archive — franchise-scoped snapshot store for soft-delete restore
      match /deletedItems/{itemId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create: if hasScopedFranchiseAccess(franchiseId);
        allow delete: if hasScopedFranchiseAccess(franchiseId);
        allow write: if hasScopedFranchiseAccess(franchiseId);
      }

      // Customer QR self-fill (return + checkout) — unauthenticated public access.
      match /returnFormData/{token} {
        allow read: if true;
        allow create: if !exists(/databases/$(database)/documents/franchises/$(franchiseId)/returnFormData/$(token))
          && publicCustomerSelfFillPayloadValid(token, franchiseId);
        allow update: if publicCustomerSelfFillNotSubmittedYet()
          && publicCustomerSelfFillPayloadValid(token, franchiseId);
        allow delete: if request.auth != null && isElevatedAdmin();
      }

      match /checkoutFormData/{token} {
        allow read: if true;
        allow create: if !exists(/databases/$(database)/documents/franchises/$(franchiseId)/checkoutFormData/$(token))
          && publicCustomerSelfFillPayloadValid(token, franchiseId);
        allow update: if publicCustomerSelfFillNotSubmittedYet()
          && publicCustomerSelfFillPayloadValid(token, franchiseId);
        allow delete: if request.auth != null && isElevatedAdmin();
      }

      // Live shuttle driver position (opt-in; doc id = driver uid)
      match /shuttleDriverLocations/{driverUid} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create, update: if hasScopedFranchiseAccess(franchiseId)
          && request.auth.uid == driverUid
          && request.resource.data.driverUid == request.auth.uid
          && request.resource.data.franchiseId == franchiseId;
        allow delete: if hasScopedFranchiseAccess(franchiseId) && request.auth.uid == driverUid;
      }

      // Condition form PDF — customer e-signature via QR (same pattern as checkoutFormData).
      match /conditionFormSignatureData/{token} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['token', 'firstName', 'lastName', 'email', 'franchiseId', 'signatureBase64'])
                      && request.resource.data.token == token
                      && request.resource.data.franchiseId == franchiseId;
        allow update: if false;
        allow delete: if request.auth != null && isElevatedAdmin();
      }

      // External garage service sends (iOS + web). Same access as other scoped franchise data;
      // document `franchiseId` must match path id (enforced by generic rule below).
      match /garageServiceJobs/{jobId} {
        allow read: if hasScopedFranchiseAccess(franchiseId) && (
          !userRoleIsGarage() || garageJobTargetMatchesUser(resource.data)
        );
        allow create: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage() &&
          request.resource.data.keys().hasAny(['franchiseId']) &&
          request.resource.data.franchiseId == franchiseId;
        allow update: if hasScopedFranchiseAccess(franchiseId) &&
          request.resource.data.keys().hasAny(['franchiseId']) &&
          request.resource.data.franchiseId == franchiseId && (
            !userRoleIsGarage() ||
            (garageJobTargetMatchesUser(resource.data) && isGaragePortalCompletionUpdate())
          );
        allow delete: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage();
      }
      match /garageServiceJobs {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }

      match /vehicleServiceFlags/{vehicleId} {
        allow read: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage();
        allow create, update: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          request.resource.data.franchiseId == franchiseId;
        allow delete: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage();
      }
      match /vehicleServiceFlags {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }

      // CH announcements (manager+ publish); team chat (staff read/write).
      match /announcements/{announcementId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create, update, delete: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          isAnnouncementPublisher() &&
          request.resource.data.franchiseId == franchiseId;
      }
      match /announcements {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }

      match /teamChatMessages/{messageId} {
        allow read: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage();
        allow create: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          request.resource.data.franchiseId == franchiseId &&
          request.resource.data.createdByUid == request.auth.uid;
        allow delete: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          resource.data.franchiseId == franchiseId &&
          resource.data.createdByUid == request.auth.uid;
        allow update: if false;
      }
      match /teamChatMessages {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }

      match /teamChatReads/{readId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create, update: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.franchiseId == franchiseId;
        allow delete: if false;
      }
      match /teamChatReads {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }

      match /teamChatPresence/{userId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create, update: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          request.auth.uid == userId &&
          request.resource.data.franchiseId == franchiseId;
        allow delete: if false;
      }
      match /teamChatPresence {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }

      match /announcementReads/{readId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create, update: if hasScopedFranchiseAccess(franchiseId) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.franchiseId == franchiseId;
        allow delete: if false;
      }
      match /announcementReads {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }

      match /announcementReactions/{reactionId} {
        allow read, delete: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage();
        allow create: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.franchiseId == franchiseId;
        allow update: if false;
      }
      match /announcementReactions {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }

      match /teamChatTyping/{userId} {
        allow read: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage();
        allow create, update: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          userId == request.auth.uid &&
          request.resource.data.franchiseId == franchiseId;
        allow delete: if hasScopedFranchiseAccess(franchiseId) &&
          !userRoleIsGarage() &&
          userId == request.auth.uid;
      }
      match /teamChatTyping {
        allow list: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage();
      }

      // Transitional scoped domain data model:
      // /franchises/{franchiseId}/{collectionName}/{docId}
      match /{collectionName}/{docId} {
        allow read: if hasScopedFranchiseAccess(franchiseId) &&
          (
            !scopedRestrictedOfficeCollection(collectionName) ||
            scopedRestrictedOfficeAccess(collectionName, franchiseId)
          );
        allow create: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage() &&
          (
            !scopedRestrictedOfficeCollection(collectionName) ||
            scopedRestrictedOfficeAccess(collectionName, franchiseId)
          ) &&
          collectionName != 'frontDeskCustomers' &&
          collectionName != 'returnFormData' &&
          collectionName != 'checkoutFormData' &&
          collectionName != 'conditionFormSignatureData' &&
          collectionName != 'announcements' &&
          collectionName != 'teamChatMessages' &&
          collectionName != 'teamChatTyping' &&
          collectionName != 'announcementReads' &&
          collectionName != 'announcementReactions' &&
          request.resource.data.keys().hasAll(['franchiseId']) &&
          request.resource.data.franchiseId == franchiseId;
        allow update: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage() &&
          (
            !scopedRestrictedOfficeCollection(collectionName) ||
            scopedRestrictedOfficeAccess(collectionName, franchiseId)
          ) &&
          collectionName != 'frontDeskCustomers' &&
          collectionName != 'returnFormData' &&
          collectionName != 'checkoutFormData' &&
          collectionName != 'conditionFormSignatureData' &&
          (
            canSoftDeleteScopedExitOrReturn(collectionName, franchiseId) ||
            (
              request.resource.data.keys().hasAll(['franchiseId']) &&
              request.resource.data.franchiseId == franchiseId
            )
          );
        allow delete: if hasScopedFranchiseAccess(franchiseId) && !userRoleIsGarage() &&
          (
            !scopedRestrictedOfficeCollection(collectionName) ||
            scopedRestrictedOfficeAccess(collectionName, franchiseId)
          ) &&
          collectionName != 'frontDeskCustomers' &&
          collectionName != 'returnFormData' &&
          collectionName != 'checkoutFormData' &&
          collectionName != 'conditionFormSignatureData';
      }
      
      match /{collectionName} {
        allow list: if hasScopedFranchiseAccess(franchiseId) &&
          (
            !scopedRestrictedOfficeCollection(collectionName) ||
            scopedRestrictedOfficeAccess(collectionName, franchiseId)
          );
      }
    }
    
    // Collection-level list (admin / tooling). Login franchise list uses callable listFranchisesForLogin.
    match /franchises {
      allow list: if isElevatedAdmin();
    }
    
    // ===== PLATE FORMATS COLLECTION (NEW) =====
    // Read-only for authenticated users, write by super admin
    
    match /plateFormats/{countryId} {
      allow read: if isAuthenticated();
      allow write: if isElevatedAdmin();
    }
    
    // Allow collection-level queries for plateFormats
    match /plateFormats {
      allow list: if isAuthenticated();
    }
    
    // ===== USERS COLLECTION =====
    
    match /users/{userId} {
      // Users can read their own profile.
      // Global admins read every user (admin panel + audit).
      allow read: if isOwner(userId) || isGlobalAdminOnly();

      // Users can update non-privileged fields on their own profile.
      // SECURITY: franchise admins are NOT allowed to write here — all admin
      // user mutations go through the Cloud Functions
      // adminCreateUserWithScope / adminUpdateUserScope / adminDeleteUserScope.
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'role',
            'roleScope',
            'isAdmin',
            'franchiseId',
            'franchiseMemberships',
            'scopeLevel',
            'defaultFranchiseId',
            'countryCode',
            'username',
            'usernameNormalized',
            'isDemo',
            'isDemoAccount',
            'isTrialUser',
            'trialStartedAt',
            'trialEndsAt',
            'trialStatus',
            'convertedAt',
            'demoExpiresAt',
            'isActive',
            'maxUsers',
            'garageId',
            'linkedGarageId'
          ]);

      // Only global admins may create / write / delete user docs directly.
      allow create, write, delete: if isGlobalAdminOnly();
    }

    // Collection-level list: global admin only.
    match /users {
      allow list: if isGlobalAdminOnly();
    }
    
    // ===== VEHICLE CATEGORIES COLLECTION =====
    // Franchise-filtered: users can only access categories in their own franchise
    
    match /vehicleCategories/{categoryId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    match /vehicleCategories {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== ARACLAR (VEHICLES) COLLECTION =====
    // Franchise-filtered: users can only access vehicles in their own franchise
    // Superadmins bypass franchise filtering
    
    match /araclar/{aracId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for araclar
    match /araclar {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== ACTIVITIES COLLECTION =====
    // Franchise-filtered: users can only access activities in their own franchise
    
    match /activities/{activityId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for activities
    match /activities {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== SERVIS KAYITLARI (SERVICE RECORDS) =====
    // Franchise-filtered: users can only access service records in their own franchise
    
    match /servisler/{servisId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for servisler
    match /servisler {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== SERVIS FIRMALARI (SERVICE COMPANIES) =====
    // Franchise-filtered: users can only access service companies in their own franchise
    
    match /servisFirmalari/{firmaId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for servisFirmalari
    match /servisFirmalari {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== IADE ISLEMLERI (RETURN OPERATIONS) =====
    // Franchise-filtered: users can only access return operations in their own franchise
    
    match /iadeIslemleri/{iadeId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    // Note: Turkey return docs may store trRentalTermsSignatureURL pointing to Storage at
    // franchises/{franchiseId}/tr_rental_terms_signatures/{file}.png (no separate Firestore collection).
    
    // Allow collection-level queries (list operations) for iadeIslemleri
    match /iadeIslemleri {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== EXIT ISLEMLERI (CHECK OUT OPERATIONS) =====
    // Franchise-filtered: users can only access check out operations in their own franchise
    
    match /exitIslemleri/{exitId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for exitIslemleri
    match /exitIslemleri {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== OFFICE OPERATIONS =====
    // Franchise-filtered: users can only access office operations in their own franchise
    
    match /office_operations/{operationId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    match /office_operations {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    match /officeOperations/{operationId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    match /officeOperations {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    match /office_Return/{returnId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    match /office_Return {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== NOTIFICATIONS COLLECTION (for push notifications) =====
    
    match /notifications/{notificationId} {
      allow read, create, update, delete: if false;
    }
    
    // ===== SMTP CONFIGURATION =====
    // Document id = franchiseId. Global admins may read/write any; franchise users read their own (Mail Center); admins/managers update.
    match /smtpConfigurations/{franchiseId} {
      allow read: if isElevatedAdmin() || (
        isAuthenticated() && canAccessFranchise(franchiseId)
      );
      allow create, update: if isElevatedAdmin() || (
        isAuthenticated() &&
        canAccessFranchise(franchiseId) &&
        (
          getUserDoc().data.role == 'admin' ||
          getUserDoc().data.role == 'superadmin' ||
          getUserDoc().data.role == 'manager'
        )
      );
      allow delete: if isElevatedAdmin();
    }
    
    // ===== OUTGOING EMAIL QUEUE =====
    // Clients can create email jobs for their franchise.
    // Cloud Functions handles status updates and sending.
    match /outgoingEmails/{emailId} {
      allow create: if hasFranchiseWriteAccess();
      allow read: if hasFranchiseReadAccess();
      allow update, delete: if false;
    }
    
    // ===== FCM TOKENS COLLECTION =====
    
    match /fcmTokens/{userId} {
      // Users can only manage their own tokens
      allow read, write: if isOwner(userId);
    }
    
    // ===== SHUTTLE REPORTS (Generated PDF reports metadata) =====
    
    match /shuttleReports/{reportId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for shuttleReports
    match /shuttleReports {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== REPORT HISTORY =====
    // Franchise-filtered: users can only access report history in their own franchise
    
    match /raporGecmisi/{raporId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for raporGecmisi
    match /raporGecmisi {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== PROTOCOL TEMPLATES (Shared Reference Data) =====
    // Templates are shared across franchises -- read by any authenticated user, write by superadmin only
    match /protocolTemplates/{templateCode} {
      allow read, list: if isAuthenticated();
      allow create, update, delete: if isElevatedAdmin();
    }
    
    // Allow collection-level queries (list operations) for protocolTemplates
    match /protocolTemplates {
      allow list: if isAuthenticated();
    }
    
    // ===== PROTOCOLS COLLECTION =====
    
    match /protocols/{protocolId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for protocols
    match /protocols {
      allow list: if legacyRootDomainFrozenRead();
    }

    // ===== DAMAGE RECORDS (Top-level) =====
    // Transitional: keep legacy nested `araclar.hasarKayitlari` and dual-write to top-level.
    match /hasarKayitlari/{damageId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }

    match /hasarKayitlari {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== USER PRESENCE COLLECTION =====
    
    match /userPresence/{userId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // ===== SHUTTLE ENTRIES =====
    
    match /shuttleEntries/{entryId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for shuttleEntries
    match /shuttleEntries {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== SHUTTLE SESSIONS =====
    
    match /shuttleSessions/{sessionId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for shuttleSessions
    match /shuttleSessions {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== TRANSACTIONS COLLECTION (ERP - Web App Specific) =====
    // Franchise-filtered: users can only access transactions in their own franchise
    
    match /transactions/{transactionId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for transactions
    match /transactions {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== CUSTOMERS COLLECTION (ERP - Web App Specific) =====
    // Franchise-filtered: users can only access customers in their own franchise
    
    match /customers/{customerId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for customers
    match /customers {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== ACCIDENTS COLLECTION (ERP - Web App Specific) =====
    // Franchise-filtered: users can only access accidents in their own franchise
    
    match /accidents/{accidentId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for accidents
    match /accidents {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== ACCIDENT CODES COLLECTION (Reference Data) =====
    // Read-only for all authenticated users (shared across franchises)
    // Write only by superadmin
    
    match /accidentCodes/{code} {
      allow read: if isAuthenticated();
      allow write: if isElevatedAdmin();
    }
    
    // Allow collection-level queries (list operations) for accidentCodes
    match /accidentCodes {
      allow list: if isAuthenticated();
    }
    
    // ===== TRAFFIC FINES COLLECTION =====
    // Franchise-filtered: users can only access traffic fines in their own franchise
    match /trafficFines/{fineId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for trafficFines
    match /trafficFines {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== BANKING TRANSACTIONS COLLECTION =====
    // Franchise-filtered: users can only access banking transactions in their own franchise
    match /bankingTransactions/{transactionId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for bankingTransactions
    match /bankingTransactions {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== ADDITIONAL SALES COLLECTION =====
    // Franchise-filtered: users can only access additional sales in their own franchise
    match /additionalSales/{saleId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for additionalSales
    match /additionalSales {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== WORK SCHEDULES (Timetable) =====
    // Franchise-filtered: users can only access work schedules in their own franchise
    
    match /workSchedules/{scheduleId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for workSchedules
    match /workSchedules {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // Alternative collection name (if used)
    match /work_schedules/{scheduleId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries for work_schedules
    match /work_schedules {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== TEST COLLECTION (superadmin only in production) =====
    
    match /test/{testId} {
      allow read, write: if isElevatedAdmin();
    }
    
    // ===== ADMIN TESTS COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage admin tests
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /adminTests/{testId} {
      // Only superadmins can write admin tests (admin panel is superadmin-only)
      allow read, write: if isElevatedAdmin();
      allow delete: if isElevatedAdmin();
    }
    
    // Allow collection-level queries (list operations) for adminTests
    match /adminTests {
      allow list: if isElevatedAdmin();
    }
    
    // ===== VACATION TIMES COLLECTION =====
    // Franchise-filtered: users can only access vacation times in their own franchise
    
    match /vacationTimes/{vacationId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for vacationTimes
    match /vacationTimes {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== ASSISTANT COMPANIES COLLECTION =====
    // Franchise-filtered: users can only access assistant companies in their own franchise
    
    match /assistantCompanies/{companyId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for assistantCompanies
    match /assistantCompanies {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== ADMIN TEST LOGS COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage admin test logs
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /adminTestLogs/{logId} {
      // Only superadmins can access admin test logs
      allow read: if isElevatedAdmin();
      allow write: if isElevatedAdmin();
      // No deletes from clients (logs should be preserved)
      allow delete: if false;
    }
    
    // Allow collection-level queries (list operations)
    match /adminTestLogs {
      allow list: if isElevatedAdmin();
    }
    
    // ===== SEMES INVOICES COLLECTION =====
    // Franchise-filtered collection
    
    match /semesInvoices/{invoiceId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for semesInvoices
    match /semesInvoices {
      allow list: if legacyRootDomainFrozenRead();
    }
    
    // ===== AUDIT LOGS COLLECTION =====
    // Franchise-filtered collection - logs should not be deleted by clients
    
    match /audit_logs/{logId} {
      allow read: if legacyRootDomainFrozenRead();
      allow write, delete: if false;
    }
    
    // Allow collection-level queries (list operations) for audit_logs
    match /audit_logs {
      allow list: if legacyRootDomainFrozenRead();
    }

    // Legacy top-level return form endpoint is disabled for client writes.
    // Active flow uses scoped path:
    // /franchises/{franchiseId}/returnFormData/{token}
    match /returnFormData/{token} {
      allow read: if request.auth != null && isElevatedAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if request.auth != null && isElevatedAdmin();
    }

    // Legacy top-level checkout form endpoint is disabled for client writes.
    // Active flow uses scoped path:
    // /franchises/{franchiseId}/checkoutFormData/{token}
    match /checkoutFormData/{token} {
      allow read: if request.auth != null && isElevatedAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if request.auth != null && isElevatedAdmin();
    }

  }
}

