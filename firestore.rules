rules_version = '2';

// ============================================================================
// FIRESTORE SECURITY RULES - FRANCHISE DATA ISOLATION + RBAC + TRIAL USERS
// ============================================================================
// Access control layers:
//   1. FRANCHISE ISOLATION: Production users can only access documents
//      matching their franchiseId (e.g. "ch" for Switzerland, "tr" for Turkey)
//   2. RBAC: Superadmins bypass franchise filtering and see all data
// ALL roles (manager, staff, viewer, admin) have FULL access to their franchise.
// ONLY superadmin has access to admin panel collections (adminTests, adminTestLogs).
//
// SAFETY: exists() checks prevent errors when user document is missing.
//         Trial users are normal franchise users with time-limited login.
//
// DEPLOYMENT ORDER: (1) Run migration, (2) Deploy app code, (3) Deploy rules
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPER FUNCTIONS =====
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get user document (returns null if not found)
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Check if user is admin (you can expand this)
    function isAdmin() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && ud.data.role == 'admin';
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isProductionUser() {
      return isAuthenticated();
    }
    
    // Validate required fields for Arac (Vehicle)
    function isValidArac() {
      return request.resource.data.keys().hasAll([
        'plaka', 'marka', 'model', 'kategori', 'vignetteVar', 
        'kayitTarihi', 'hasarKayitlari', 'qrCode', 'spareKeyCount'
      ]) &&
      request.resource.data.plaka is string &&
      request.resource.data.marka is string &&
      request.resource.data.model is string &&
      request.resource.data.kategori is string &&
      request.resource.data.vignetteVar is bool &&
      request.resource.data.kayitTarihi is timestamp &&
      request.resource.data.hasarKayitlari is list &&
      request.resource.data.qrCode is string &&
      request.resource.data.spareKeyCount is int;
    }
    
    // ===== HELPER FUNCTION: CHECK SUPER ADMIN =====
    
    // Check if user is super admin (role-based, no email hardcode)
    function isSuperAdmin() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && ud.data.role == 'superadmin';
    }
    
    // Franchise manager: operational lead (work-hour visibility for whole team)
    function isFranchiseManagerRole() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && ud.data.role == 'manager';
    }
    
    // Check if user belongs to a franchise
    function belongsToFranchise(franchiseId) {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null &&
        ud.data.franchiseId.lower() == franchiseId.lower();
    }
    
    // Check if user is active
    function isActiveUser() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        ud.data.isActive == true ||
        ud.data.isActive == 1 ||
        ud.data.isActive == "1" ||
        !ud.data.keys().hasAny(["isActive"])
      );
    }
    
    // ===== FRANCHISE DATA ISOLATION HELPERS =====
    // Single get() per function using let + null check pattern
    // ALL roles (manager, staff, viewer, admin) get FULL franchise access
    // ONLY superadmin bypasses franchise filtering
    // Trial users are NOT isolated by path; all active users use franchise paths.
    
    // Check if user has franchise access to read a document
    // NOTE: Documents WITHOUT a franchiseId field are denied for non-superadmin users
    // to prevent legacy/malformed data from bypassing franchise isolation.
    function hasFranchiseReadAccess() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        ud.data.role == 'superadmin' ||
        (
          (ud.data.isActive == true ||
           ud.data.isActive == 1 ||
           ud.data.isActive == "1" ||
           !ud.data.keys().hasAny(["isActive"])) &&
          resource.data.keys().hasAny(["franchiseId"]) &&
          resource.data.franchiseId.lower() == ud.data.franchiseId.lower()
        )
      );
    }
    
    // Check if user has franchise access to write a document
    // NOTE: Writes must include franchiseId matching the user's franchise.
    function hasFranchiseWriteAccess() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        ud.data.role == 'superadmin' ||
        (
          (ud.data.isActive == true ||
           ud.data.isActive == 1 ||
           ud.data.isActive == "1" ||
           !ud.data.keys().hasAny(["isActive"])) &&
          request.resource.data.keys().hasAny(["franchiseId"]) &&
          request.resource.data.franchiseId.lower() == ud.data.franchiseId.lower()
        )
      );
    }
    
    // Check if user has franchise access to delete a document
    // NOTE: Documents WITHOUT franchiseId are only deletable by superadmin.
    function hasFranchiseDeleteAccess() {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        ud.data.role == 'superadmin' ||
        (
          (ud.data.isActive == true ||
           ud.data.isActive == 1 ||
           ud.data.isActive == "1" ||
           !ud.data.keys().hasAny(["isActive"])) &&
          resource.data.keys().hasAny(["franchiseId"]) &&
          resource.data.franchiseId.lower() == ud.data.franchiseId.lower()
        )
      );
    }
    
    // Scoped-path access helper: franchises/{franchiseId}/{collection}/{doc}
    function hasScopedFranchiseAccess(franchiseId) {
      let ud = getUserDoc();
      return isAuthenticated() && ud != null && (
        ud.data.isActive == true ||
        ud.data.isActive == 1 ||
        ud.data.isActive == "1" ||
        !ud.data.keys().hasAny(["isActive"])
      ) &&
        (ud.data.role == 'superadmin' ||
         ud.data.franchiseId.lower() == franchiseId.lower());
    }

    // Front-desk customer intakes (web kiosk): admin SDK creates; staff completes RES + plate only.
    function isFrontDeskStaffCompletionUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['resCode', 'vehiclePlate', 'status', 'completedAt'])
        && request.resource.data.status == 'completed'
        && request.resource.data.resCode is string
        && request.resource.data.vehiclePlate is string
        && request.resource.data.resCode.size() > 0
        && request.resource.data.vehiclePlate.size() > 0
        && request.resource.data.completedAt is timestamp
        && resource.data.status == 'awaiting_staff';
    }
    
    // ===== FRANCHISES COLLECTION (NEW) =====
    // Only super admin can manage franchises
    
    match /franchises/{franchiseId} {
      // Super admin can do everything
      allow read, write, delete: if isSuperAdmin();
      
      // Authenticated users can read their own franchise
      allow read: if isAuthenticated() && belongsToFranchise(franchiseId);
      
      // Scoped notification queue (Cloud Functions processor)
      match /notifications/{notificationId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create: if hasScopedFranchiseAccess(franchiseId);
        allow update, delete: if false;
      }
      
      // Scoped outgoing email queue (Cloud Functions processor)
      match /outgoingEmails/{emailId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create: if hasScopedFranchiseAccess(franchiseId);
        allow update, delete: if false;
      }
      
      // Per-user work time entries (strict read: own row OR franchise manager OR superadmin)
      match /workTimeEntries/{docId} {
        allow read: if isSuperAdmin() || (
          hasScopedFranchiseAccess(franchiseId) && (
            isFranchiseManagerRole() ||
            (resource.data.keys().hasAll(['userId']) && resource.data.userId == request.auth.uid)
          )
        );
        allow create: if hasScopedFranchiseAccess(franchiseId) &&
          request.resource.data.keys().hasAll([
            'franchiseId', 'userId', 'dayKey', 'clockIn', 'clockOut', 'totalMinutes', 'updatedAt'
          ]) &&
          request.resource.data.franchiseId == franchiseId &&
          request.resource.data.userId == request.auth.uid;
        allow update: if hasScopedFranchiseAccess(franchiseId) &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == resource.data.userId &&
          resource.data.franchiseId == franchiseId &&
          request.resource.data.franchiseId == franchiseId;
        allow delete: if hasScopedFranchiseAccess(franchiseId) &&
          resource.data.userId == request.auth.uid;
      }
      
      // Monthly plan files uploaded by managers/admins for each franchise
      match /workTimePlans/{docId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create, update: if hasScopedFranchiseAccess(franchiseId) && (
          isFranchiseManagerRole() || isSuperAdmin() || isAdmin()
        );
        allow delete: if hasScopedFranchiseAccess(franchiseId) && (
          isFranchiseManagerRole() || isSuperAdmin() || isAdmin()
        );
      }

      match /frontDeskCustomers/{docId} {
        allow read: if hasScopedFranchiseAccess(franchiseId) && isActiveUser();
        allow create: if false;
        allow update: if hasScopedFranchiseAccess(franchiseId) && isActiveUser() && isFrontDeskStaffCompletionUpdate();
        allow delete: if isSuperAdmin() && isActiveUser();
      }

      // Deleted item archive — franchise-scoped snapshot store for soft-delete restore
      match /deletedItems/{itemId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create: if hasScopedFranchiseAccess(franchiseId);
        allow delete: if hasScopedFranchiseAccess(franchiseId);
        allow write: if hasScopedFranchiseAccess(franchiseId);
      }

      // Customer QR self-fill form — unauthenticated public access.
      // The iOS app generates a unique UUID token per return and encodes it in the QR code.
      // The customer scans the QR, fills in their details, and the iOS app reads the result.
      // Token-in-document check prevents writing to arbitrary documents.
      match /returnFormData/{token} {
        // Allow unauthenticated read so the form can detect "already submitted" state.
        allow read: if true;
        // Allow unauthenticated create; require token field to match the document ID.
        allow create: if request.resource.data.keys().hasAll(['token', 'firstName', 'lastName', 'email'])
                      && request.resource.data.token == token;
        // Updates are forbidden — form is write-once.
        allow update: if false;
        // Deletion is admin-only.
        allow delete: if request.auth != null && isSuperAdmin();
      }

      // Transitional scoped domain data model:
      // /franchises/{franchiseId}/{collectionName}/{docId}
      match /{collectionName}/{docId} {
        allow read: if hasScopedFranchiseAccess(franchiseId);
        allow create, update: if hasScopedFranchiseAccess(franchiseId) &&
          collectionName != 'frontDeskCustomers' &&
          request.resource.data.keys().hasAll(['franchiseId']) &&
          request.resource.data.franchiseId == franchiseId;
        allow delete: if hasScopedFranchiseAccess(franchiseId) && collectionName != 'frontDeskCustomers';
      }
      
      match /{collectionName} {
        allow list: if hasScopedFranchiseAccess(franchiseId);
      }
    }
    
    // Allow collection-level queries for franchises
    match /franchises {
      allow list: if isSuperAdmin();
    }
    
    // ===== PLATE FORMATS COLLECTION (NEW) =====
    // Read-only for authenticated users, write by super admin
    
    match /plateFormats/{countryId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    // Allow collection-level queries for plateFormats
    match /plateFormats {
      allow list: if isAuthenticated();
    }
    
    // ===== USERS COLLECTION =====
    
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      
      // Users can update their own profile (limited fields)
      allow update: if isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'role',
            'isAdmin',
            'franchiseId',
            'isDemo',
            'isDemoAccount',
            'isTrialUser',
            'trialStartedAt',
            'trialEndsAt',
            'trialStatus',
            'convertedAt',
            'demoExpiresAt',
            'isActive',
            'maxUsers'
          ]);
      
      // Super admin can do everything with users
      allow read, write, delete: if isSuperAdmin();
    }
    
    // Allow collection-level queries for users
    match /users {
      allow list: if isSuperAdmin();
    }
    
    // ===== VEHICLE CATEGORIES COLLECTION =====
    // Franchise-filtered: users can only access categories in their own franchise
    
    match /vehicleCategories/{categoryId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    match /vehicleCategories {
      allow list: if isProductionUser();
    }
    
    // ===== ARACLAR (VEHICLES) COLLECTION =====
    // Franchise-filtered: users can only access vehicles in their own franchise
    // Superadmins bypass franchise filtering
    
    match /araclar/{aracId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for araclar
    match /araclar {
      allow list: if isProductionUser();
    }
    
    // ===== ACTIVITIES COLLECTION =====
    // Franchise-filtered: users can only access activities in their own franchise
    
    match /activities/{activityId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for activities
    match /activities {
      allow list: if isProductionUser();
    }
    
    // ===== SERVIS KAYITLARI (SERVICE RECORDS) =====
    // Franchise-filtered: users can only access service records in their own franchise
    
    match /servisler/{servisId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for servisler
    match /servisler {
      allow list: if isProductionUser();
    }
    
    // ===== SERVIS FIRMALARI (SERVICE COMPANIES) =====
    // Franchise-filtered: users can only access service companies in their own franchise
    
    match /servisFirmalari/{firmaId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for servisFirmalari
    match /servisFirmalari {
      allow list: if isProductionUser();
    }
    
    // ===== IADE ISLEMLERI (RETURN OPERATIONS) =====
    // Franchise-filtered: users can only access return operations in their own franchise
    
    match /iadeIslemleri/{iadeId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for iadeIslemleri
    match /iadeIslemleri {
      allow list: if isProductionUser();
    }
    
    // ===== EXIT ISLEMLERI (CHECK OUT OPERATIONS) =====
    // Franchise-filtered: users can only access check out operations in their own franchise
    
    match /exitIslemleri/{exitId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for exitIslemleri
    match /exitIslemleri {
      allow list: if isProductionUser();
    }
    
    // ===== OFFICE OPERATIONS =====
    // Franchise-filtered: users can only access office operations in their own franchise
    
    match /office_operations/{operationId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for office_operations
    match /office_operations {
      allow list: if isProductionUser();
    }
    
    // Alternative collection name (if used)
    match /officeOperations/{operationId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries for officeOperations
    match /officeOperations {
      allow list: if isProductionUser();
    }
    
    // ===== OFFICE RETURNS (CUSTOMER RETURNS) =====
    // Franchise-filtered: users can only access office returns in their own franchise
    
    match /office_Return/{returnId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for office_Return
    match /office_Return {
      allow list: if isProductionUser();
    }
    
    // ===== NOTIFICATIONS COLLECTION (for push notifications) =====
    
    match /notifications/{notificationId} {
      allow read, create, update, delete: if false;
    }
    
    // ===== SMTP CONFIGURATION =====
    // Stored per franchise.
    match /smtpConfigurations/{franchiseId} {
      // SMTP credentials are secrets: never expose to regular franchise users.
      allow read, write, delete: if isSuperAdmin();
    }
    
    // ===== OUTGOING EMAIL QUEUE =====
    // Clients can create email jobs for their franchise.
    // Cloud Functions handles status updates and sending.
    match /outgoingEmails/{emailId} {
      allow create: if hasFranchiseWriteAccess();
      allow read: if hasFranchiseReadAccess();
      allow update, delete: if false;
    }
    
    // ===== FCM TOKENS COLLECTION =====
    
    match /fcmTokens/{userId} {
      // Users can only manage their own tokens
      allow read, write: if isOwner(userId);
    }
    
    // ===== SHUTTLE REPORTS (Generated PDF reports metadata) =====
    
    match /shuttleReports/{reportId} {
      allow read: if hasFranchiseReadAccess();
      allow create, update: if hasFranchiseWriteAccess() &&
        request.resource.data.keys().hasAll([
          'type', 'startDate', 'endDate', 'totalSessions', 'totalCustomers', 'totalTrips', 'generatedAt'
        ]);
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for shuttleReports
    match /shuttleReports {
      allow list: if isProductionUser();
    }
    
    // ===== REPORT HISTORY =====
    // Franchise-filtered: users can only access report history in their own franchise
    
    match /raporGecmisi/{raporId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for raporGecmisi
    match /raporGecmisi {
      allow list: if isProductionUser();
    }
    
    // ===== PROTOCOL TEMPLATES (Shared Reference Data) =====
    // Templates are shared across franchises -- read by any authenticated user, write by superadmin only
    match /protocolTemplates/{templateCode} {
      allow read, list: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }
    
    // Allow collection-level queries (list operations) for protocolTemplates
    match /protocolTemplates {
      allow list: if isAuthenticated();
    }
    
    // ===== PROTOCOLS COLLECTION =====
    
    match /protocols/{protocolId} {
      allow read: if hasFranchiseReadAccess();
      allow create: if hasFranchiseWriteAccess();
      allow update: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for protocols
    match /protocols {
      allow list: if isProductionUser();
    }

    // ===== DAMAGE RECORDS (Top-level) =====
    // Transitional: keep legacy nested `araclar.hasarKayitlari` and dual-write to top-level.
    match /hasarKayitlari/{damageId} {
      allow read: if hasFranchiseReadAccess();
      allow create, update: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }

    match /hasarKayitlari {
      allow list: if isProductionUser();
    }
    
    // ===== USER PRESENCE COLLECTION =====
    
    match /userPresence/{userId} {
      // Superadmin can inspect presence globally.
      allow read: if isSuperAdmin() ||
        (isAuthenticated() && getUserDoc() != null &&
         resource.data.keys().hasAny(["franchiseId"]) &&
         resource.data.franchiseId.lower() == getUserDoc().data.franchiseId.lower());
      
      // Users can only write their own presence in their franchise.
      allow create, update: if isOwner(userId) &&
        getUserDoc() != null &&
        request.resource.data.keys().hasAll(["franchiseId"]) &&
        request.resource.data.franchiseId.lower() == getUserDoc().data.franchiseId.lower();
      
      allow delete: if isSuperAdmin();
    }
    
    // ===== SHUTTLE ENTRIES =====
    
    match /shuttleEntries/{entryId} {
      allow read: if hasFranchiseReadAccess();
      allow create: if hasFranchiseWriteAccess();
      allow update: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for shuttleEntries
    match /shuttleEntries {
      allow list: if isProductionUser();
    }
    
    // ===== SHUTTLE SESSIONS =====
    
    match /shuttleSessions/{sessionId} {
      allow read: if hasFranchiseReadAccess();
      allow create: if hasFranchiseWriteAccess();
      allow update: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for shuttleSessions
    match /shuttleSessions {
      allow list: if isProductionUser();
    }
    
    // ===== TRANSACTIONS COLLECTION (ERP - Web App Specific) =====
    // Franchise-filtered: users can only access transactions in their own franchise
    
    match /transactions/{transactionId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for transactions
    match /transactions {
      allow list: if isProductionUser();
    }
    
    // ===== CUSTOMERS COLLECTION (ERP - Web App Specific) =====
    // Franchise-filtered: users can only access customers in their own franchise
    
    match /customers/{customerId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for customers
    match /customers {
      allow list: if isProductionUser();
    }
    
    // ===== ACCIDENTS COLLECTION (ERP - Web App Specific) =====
    // Franchise-filtered: users can only access accidents in their own franchise
    
    match /accidents/{accidentId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for accidents
    match /accidents {
      allow list: if isProductionUser();
    }
    
    // ===== ACCIDENT CODES COLLECTION (Reference Data) =====
    // Read-only for all authenticated users (shared across franchises)
    // Write only by superadmin
    
    match /accidentCodes/{code} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    // Allow collection-level queries (list operations) for accidentCodes
    match /accidentCodes {
      allow list: if isAuthenticated();
    }
    
    // ===== TRAFFIC FINES COLLECTION =====
    // Franchise-filtered: users can only access traffic fines in their own franchise
    match /trafficFines/{fineId} {
      allow read: if hasFranchiseReadAccess();
      allow create: if hasFranchiseWriteAccess();
      allow update: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for trafficFines
    match /trafficFines {
      allow list: if isProductionUser();
    }
    
    // ===== BANKING TRANSACTIONS COLLECTION =====
    // Franchise-filtered: users can only access banking transactions in their own franchise
    match /bankingTransactions/{transactionId} {
      allow read: if hasFranchiseReadAccess();
      allow create: if hasFranchiseWriteAccess();
      allow update: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for bankingTransactions
    match /bankingTransactions {
      allow list: if isProductionUser();
    }
    
    // ===== ADDITIONAL SALES COLLECTION =====
    // Franchise-filtered: users can only access additional sales in their own franchise
    match /additionalSales/{saleId} {
      allow read: if hasFranchiseReadAccess();
      allow create: if hasFranchiseWriteAccess();
      allow update: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for additionalSales
    match /additionalSales {
      allow list: if isProductionUser();
    }
    
    // ===== WORK SCHEDULES (Timetable) =====
    // Franchise-filtered: users can only access work schedules in their own franchise
    
    match /workSchedules/{scheduleId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for workSchedules
    match /workSchedules {
      allow list: if isProductionUser();
    }
    
    // Alternative collection name (if used)
    match /work_schedules/{scheduleId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries for work_schedules
    match /work_schedules {
      allow list: if isProductionUser();
    }
    
    // ===== TEST COLLECTION (superadmin only in production) =====
    
    match /test/{testId} {
      allow read, write: if isSuperAdmin();
    }
    
    // ===== ADMIN TESTS COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage admin tests
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /adminTests/{testId} {
      // Only superadmins can write admin tests (admin panel is superadmin-only)
      allow read, write: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
    
    // Allow collection-level queries (list operations) for adminTests
    match /adminTests {
      allow list: if isSuperAdmin();
    }
    
    // ===== VACATION TIMES COLLECTION =====
    // Franchise-filtered: users can only access vacation times in their own franchise
    
    match /vacationTimes/{vacationId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for vacationTimes
    match /vacationTimes {
      allow list: if isProductionUser();
    }
    
    // ===== ASSISTANT COMPANIES COLLECTION =====
    // Franchise-filtered: users can only access assistant companies in their own franchise
    
    match /assistantCompanies/{companyId} {
      allow read: if hasFranchiseReadAccess();
      allow write: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for assistantCompanies
    match /assistantCompanies {
      allow list: if isProductionUser();
    }
    
    // ===== ADMIN TEST LOGS COLLECTION =====
    // PERMANENT: All authenticated users have full access
    // DO NOT CHANGE: This allows all authenticated users to manage admin test logs
    // DEMO USERS CANNOT ACCESS PRODUCTION DATA
    
    match /adminTestLogs/{logId} {
      // Only superadmins can access admin test logs
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
      // No deletes from clients (logs should be preserved)
      allow delete: if false;
    }
    
    // Allow collection-level queries (list operations)
    match /adminTestLogs {
      allow list: if isSuperAdmin();
    }
    
    // ===== SEMES INVOICES COLLECTION =====
    // Franchise-filtered collection
    
    match /semesInvoices/{invoiceId} {
      allow read: if hasFranchiseReadAccess();
      allow create: if hasFranchiseWriteAccess();
      allow update: if hasFranchiseWriteAccess();
      allow delete: if hasFranchiseDeleteAccess();
    }
    
    // Allow collection-level queries (list operations) for semesInvoices
    match /semesInvoices {
      allow list: if isProductionUser();
    }
    
    // ===== AUDIT LOGS COLLECTION =====
    // Franchise-filtered collection - logs should not be deleted by clients
    
    match /audit_logs/{logId} {
      allow read: if hasFranchiseReadAccess();
      allow create: if hasFranchiseWriteAccess();
      allow update: if hasFranchiseWriteAccess();
      // No deletes from clients (audit logs should be preserved)
      allow delete: if false;
    }
    
    // Allow collection-level queries (list operations) for audit_logs
    match /audit_logs {
      allow list: if isProductionUser();
    }

    // Customer QR self-fill form submissions — unauthenticated writes allowed
    // Token-in-document check prevents arbitrary document creation
    match /returnFormData/{token} {
      // Web customers are unauthenticated, so they must be able to detect
      // "already submitted" state to avoid re-writing (update is denied).
      // Some older documents may miss `submittedAt`, so allow reads when any
      // of the expected payload fields exist.
      allow read: if request.auth != null ||
        (resource.data.keys().hasAny(['submittedAt','signatureBase64','firstName','lastName','email']));
      allow create: if request.resource.data.keys().hasAll(['token', 'firstName', 'lastName', 'email'])
                    && request.resource.data.token == token;
      allow update: if false;
      allow delete: if request.auth != null && isSuperAdmin();
    }

  }
}

