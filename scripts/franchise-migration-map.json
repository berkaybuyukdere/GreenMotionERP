{
  "defaultFranchiseId": "CH",
  "globalFirestoreCollections": [
    "users",
    "franchises",
    "notifications",
    "outgoingEmails",
    "smtpConfigurations",
    "plateFormats",
    "protocolTemplates",
    "accidentCodes",
    "fcmTokens",
    "adminTests",
    "adminTestLogs"
  ],
  "domainFirestoreCollections": [
    "araclar",
    "servisler",
    "iadeIslemleri",
    "exitIslemleri",
    "activities",
    "servisFirmalari",
    "office_operations",
    "officeOperations",
    "office_Return",
    "workSchedules",
    "work_schedules",
    "vacationTimes",
    "assistantCompanies",
    "protocols",
    "shuttleEntries",
    "shuttleSessions",
    "shuttleReports",
    "trafficFines",
    "bankingTransactions",
    "additionalSales",
    "semesInvoices",
    "audit_logs",
    "vehicleCategories",
    "userPresence",
    "raporGecmisi",
    "hasarKayitlari",
    "transactions",
    "customers",
    "accidents"
  ],
  "migrationMetadata": {
    "scopedField": "_migration",
    "legacyMarkerField": "_migrationLegacy",
    "copyCallable": "migrateLegacyToScoped",
    "cleanupCallable": "cleanupVerifiedLegacyDocs",
    "parityCallable": "getLegacyScopedParity"
  },
  "firestorePathTemplate": {
    "legacy": "{collection}/{docId}",
    "scoped": "franchises/{franchiseId}/{collection}/{docId}"
  },
  "storagePrefixes": [
    "hasar_fotograflari",
    "iade_fotograflari",
    "exit_fotograflari",
    "office_operations",
    "office_Return",
    "kafa_kagitlari",
    "iade_signatures",
    "return_pdfs"
  ],
  "storagePathTemplate": {
    "legacy": "{prefix}/{rest}",
    "scoped": "franchises/{franchiseId}/{prefix}/{rest}"
  }
}
