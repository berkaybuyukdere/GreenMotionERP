rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ===== HELPER FUNCTIONS =====
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isPDFFile() {
      return request.resource.contentType == 'application/pdf';
    }
    
    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024; // 10MB
    }
    
    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024; // 5MB
    }
    
    // ===== HASAR FOTOGRAFLARI (DAMAGE PHOTOS) =====
    // All authenticated users can upload, read, and delete damage photos
    // DO NOT CHANGE: This allows all authenticated users to manage damage photos
    
    match /hasar_fotograflari/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        isImageFile() && 
        isUnder10MB();
      allow delete: if isAuthenticated();
    }
    
    // Alternative path structure (if you use this)
    match /damages/{aracId}/{hasarId}/{imageName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        isImageFile() && 
        isUnder10MB();
      allow delete: if isAuthenticated();
    }
    
    // ===== IADE FOTOGRAFLARI (RETURN PHOTOS) =====
    // All authenticated users can upload, read, and delete return photos
    // DO NOT CHANGE: This allows all authenticated users to manage return photos
    
    match /iade_fotograflari/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        isImageFile() && 
        isUnder10MB();
      allow delete: if isAuthenticated();
    }
    
    // ===== EXIT FOTOGRAFLARI (CHECK OUT PHOTOS) =====
    // All authenticated users can upload, read, and delete check out photos
    // DO NOT CHANGE: This allows all authenticated users to manage check out photos
    
    match /exit_fotograflari/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        isImageFile() && 
        isUnder10MB();
      allow delete: if isAuthenticated();
    }
    
    // ===== OFFICE OPERATION PHOTOS =====
    // All authenticated users can upload, read, and delete office operation photos
    // DO NOT CHANGE: This allows all authenticated users to manage office operation photos
    
    match /office_operations/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        isImageFile() && 
        isUnder10MB();
      allow delete: if isAuthenticated();
    }
    
    // ===== OFFICE RETURN PHOTOS (CUSTOMER RETURNS) =====
    
    match /office_Return/{returnId}/{imageName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        isImageFile() && 
        isUnder10MB();
      allow delete: if isAuthenticated();
    }
    
    // ===== HEAD DOCUMENTS (Vehicle Registration Papers) =====
    
    match /head_documents/{aracId}/{documentName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        (isImageFile() || isPDFFile()) && 
        isUnder10MB();
      allow delete: if isAuthenticated();
    }
    
    // ===== PDF EXPORTS =====
    
    match /pdf_exports/{userId}/{pdfName} {
      // Users can only access their own PDFs
      allow read: if isAuthenticated() && 
        request.auth.uid == userId;
      
      allow write: if isAuthenticated() && 
        request.auth.uid == userId &&
        isPDFFile() &&
        isUnder10MB();
      
      allow delete: if isAuthenticated() && 
        request.auth.uid == userId;
    }
    
    // ===== SERVIS FOTOGRAFLARI (SERVICE PHOTOS) =====
    
    match /servis_fotograflari/{userId}/{servisId}/{imageName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        isImageFile() && 
        isUnder5MB();
      allow delete: if isAuthenticated();
    }
    
    // ===== USER PROFILE PHOTOS =====
    
    match /profile_photos/{userId}/{imageName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        request.auth.uid == userId &&
        isImageFile() && 
        isUnder5MB();
      allow delete: if isAuthenticated() && 
        request.auth.uid == userId;
    }
    
    // ===== TEMPORARY UPLOADS (auto-delete after 24h) =====
    
    match /temp/{userId}/{fileName} {
      allow read: if isAuthenticated() && 
        request.auth.uid == userId;
      
      allow write: if isAuthenticated() && 
        request.auth.uid == userId &&
        isUnder10MB();
      
      allow delete: if isAuthenticated() && 
        request.auth.uid == userId;
    }
    
    // ===== ADMIN TEST FILES =====
    // All authenticated users can use test folder for admin testing
    // DO NOT CHANGE: This allows all authenticated users to manage test files
    
    match /test/{allPaths=**} {
      // Allow all operations for authenticated users
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isUnder10MB();
      allow delete: if isAuthenticated();
    }
    
    // Allow listing test folder contents
    match /test {
      allow list: if isAuthenticated();
    }
    
    // ===== DENY ALL OTHER PATHS =====
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

